# BasicCategoryFlow

main: kit: flow: BasicCategoryFlow:
{
  entity: "category",
  kind: "basic",
  name: "BasicCategoryFlow",
  step: [
    {
      op: "list",
      valid: [
        {
          apply: "ItemExists",
          def: {
            ref: "category_ref01"
          }
        }
      ]
    }

    {
      input: {
        ref: "category_ref01",
        srcdatavar: "category_ref01_data",
        suffix: "_dt0"
      }

      match: {
        id: "category01"
      }

      op: "load",
      valid: [
        {
          apply: "TextFieldMark",
          def: {
            mark: "Mark01-category_ref01"
          }
        }
      ]
    }
  ],
  "key$": "BasicCategoryFlow"
}